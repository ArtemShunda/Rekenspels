<Window x:Class="Rekenspels.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rekenspels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Name="back" Background="LightYellow">
        <Grid.RowDefinitions>
            <RowDefinition Height="58*"/>
            <RowDefinition Height="159*"/>
        </Grid.RowDefinitions>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,35,0,0" Grid.RowSpan="2">
            <Rectangle HorizontalAlignment="Left" Height="365" Stroke="Black" Fill="White" VerticalAlignment="Top" Width="258" RadiusX="26.5" RadiusY="26.5"/>
            <TextBlock HorizontalAlignment="Left" Margin="67,19,0,0" TextWrapping="Wrap" Text="Het Rekenspel" FontSize="20px" Foreground="Orange" FontWeight="Bold" VerticalAlignment="Top"/>
            <Button Name="checkRes" Content="Check Antwoord" HorizontalAlignment="Left" Margin="71,144,0,0" VerticalAlignment="Top" Width="116"  Click="Check_Button_Click" Background="green" Foreground="white" Height="22"/>
            <Button Content="Nieuwe Som" HorizontalAlignment="Left" Margin="71,182,0,0" VerticalAlignment="Top" Width="116"  Click="Button_NewSum" Background="darkblue" Foreground="white" Height="22"/>
            <Button Name="mathBut" Content="Start" HorizontalAlignment="Left" Margin="89,317,0,0" VerticalAlignment="Top" Width="80"  Click="Button_Click" Background="pink" Foreground="white" Height="19"/>
            <Button Content="Restart" HorizontalAlignment="Center" Margin="0,291,0,0" VerticalAlignment="Top" Width="114"  Click="Restart_Button_Click" Background="purple" Foreground="white" Height="21"/>
            <TextBlock HorizontalAlignment="Left" Margin="93,265,0,0" TextWrapping="Wrap" Text="✭Score:" VerticalAlignment="Top"/>
            <TextBlock x:Name="score" HorizontalAlignment="Left" Margin="147,265,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top" Height="14" RenderTransformOrigin="0.5,0.5" Width="15">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="14,39,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="🧡"/>
            <TextBlock Name ="hp" HorizontalAlignment="Left" Margin="34,40,0,0" TextWrapping="Wrap" Text="3" VerticalAlignment="Top" Height="15" Width="10"/>
            <TextBlock HorizontalAlignment="Left" Margin="89,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" Text="⌛Time:" Height="16"/>
            <TextBlock HorizontalAlignment="Left" Margin="79,246,0,0" TextWrapping="Wrap" Text="🥇Record:" VerticalAlignment="Top"/>
            <TextBlock Name="Record" HorizontalAlignment="Left" Margin="147,246,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Height="14" RenderTransformOrigin="0.5,0.5" Width="15" />
            <TextBlock TextAlignment="Center" Name="firstNum" HorizontalAlignment="Left" Margin="91,62,0,0" VerticalAlignment="Top" FontSize="20px
                   "/>
            <TextBlock TextAlignment="Center" Name="mathOp" HorizontalAlignment="Left" Margin="119,61,0,0" VerticalAlignment="Top" FontSize="20px
                   " RenderTransformOrigin="0.298,0.511"/>
            <TextBlock TextAlignment="Center" Name="secondNum" HorizontalAlignment="Left" Margin="141,62,0,0" VerticalAlignment="Top" FontSize="20px
                   " RenderTransformOrigin="0.49,0.272"/>
            <Button Name="pauseBtn" Content="⏸" HorizontalAlignment="Left" Margin="203,106,0,0" VerticalAlignment="Top" Height="32" Background="white" Foreground="black" FontSize="22px" Width="34" Click="Button_Pause"/>
            <TextBlock HorizontalAlignment="Center" Margin="0,56,0,0" TextWrapping="Wrap" FontSize="20px" Foreground="Orange" FontWeight="Bold" VerticalAlignment="Top"/>
            <TextBox Name="timerTB" HorizontalAlignment="Left" Margin="139,226,0,0" TextWrapping="Wrap" Text="99" VerticalAlignment="Top" Width="23" />
            <TextBox Name="resultTB" HorizontalAlignment="Left" Margin="86,109,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90" Height="25" TextChanged="resultTB_TextChanged" />
            <Button Name="soundBtn" Content="🔊 ON" HorizontalAlignment="Left" Margin="195,144,0,0" VerticalAlignment="Top" Background="Lavender" Foreground="White" Click="Button_Sound" Height="22" Width="50"/>
            <TextBlock HorizontalAlignment="Left" Margin="105,3,0,0" TextWrapping="Wrap" Text="Level" VerticalAlignment="Top"/>
            <TextBlock Name="Level" HorizontalAlignment="Left" Margin="137,3,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top"/>
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="582,47,0,0" Grid.RowSpan="2">
            <Rectangle HorizontalAlignment="Left" Height="145" Stroke="Black" Fill="white" VerticalAlignment="Top" Width="156" RadiusX="14.062" RadiusY="14.062"/>
            <TextBlock HorizontalAlignment="Left" Margin="26,8,0,0" TextWrapping="Wrap" Foreground="Purple" FontWeight="Bold" VerticalAlignment="Top" Text="Moeilijkheidsniveau"/>
            <Button Name="Easy" Content="Makkelijk" Background="green" Click="Easy_Button_Click" FontWeight="Bold"  HorizontalAlignment="Left" Margin="33,35,0,0" VerticalAlignment="Top" Width="90" Height="27"/>
            <Button Name="Normal" Content="Normaal" Background="orange" Click="Mid_Button_Click" FontWeight="Bold" HorizontalAlignment="Left" Margin="33,68,0,0" VerticalAlignment="Top" Width="90" Height="30"/>
            <Button Name="Hard" Content="Moelijk" Background="red" Click="Hard_Button_Click" FontWeight="Bold" HorizontalAlignment="Left" Margin="33,104,0,0" VerticalAlignment="Top" Width="90" Height="30"/>
        </Grid>
        <Rectangle HorizontalAlignment="Left" Height="170" Margin="96,47,0,0" Stroke="Black" Fill ="White" VerticalAlignment="Top" Width="58" RadiusX="14.062" RadiusY="14.062" Grid.RowSpan="2"/>
        <TextBlock HorizontalAlignment="Left" Margin="103,52,0,0" TextWrapping="Wrap" Text="Operator" VerticalAlignment="Top" Foreground="Purple"/>
        <Button Content="+" HorizontalAlignment="Left" Margin="111,73,0,0" VerticalAlignment="Top" Click="Button_Plus" Width="30" Background="#FFE90D0D"/>
        <Button Content="-" HorizontalAlignment="Left" Margin="111,101,0,0" VerticalAlignment="Top" Width="30" Grid.RowSpan="2" Click="Button_Min" Background="#FFFA6713"/>
        <Button Content="*" HorizontalAlignment="Left" Margin="111,14,0,0" VerticalAlignment="Top" Width="30" Grid.Row="1" Click="Button_Keer" Background="#FFF0DA12"/>
        <Button Content="/" HorizontalAlignment="Left" Margin="111,43,0,0" VerticalAlignment="Top" Width="30" Grid.Row="1" Click="Button_Del" Background="#FF8BE915"/>
        <Button Content="Random" HorizontalAlignment="Left" Margin="105,70,0,0" Grid.Row="1" VerticalAlignment="Top" FontSize="10" Background="#FF17F0A9" Click="Button_Rand" />
    </Grid>
</Window>
