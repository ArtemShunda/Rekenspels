<Window x:Class="Rekenspels.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rekenspels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Name="back" Background="LightYellow">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Rectangle Height="365" Stroke="Black" Fill="White" Width="258" RadiusX="26.5" RadiusY="26.5" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBlock TextWrapping="Wrap" Text="Het Rekenspel" FontSize="20px" Foreground="Orange" FontWeight="Bold" VerticalAlignment="Top" Margin="62,21,0,0" HorizontalAlignment="Left"/>
            <Button x:Name="checkRes" Content="Check Antwoord" VerticalAlignment="Top" Width="116"  Click="Check_Button_Click" Background="green" Foreground="white" Height="22" Margin="71,144,0,0" HorizontalAlignment="Left"/>
            <Button Content="Nieuwe Som" HorizontalAlignment="Left" Margin="71,182,0,0" VerticalAlignment="Top" Width="116"  Click="Button_Click" Background="darkblue" Foreground="white" Height="22"/>
            <Button x:Name="mathBut" Content="Start" HorizontalAlignment="Left" Margin="89,317,0,0" VerticalAlignment="Top" Width="80"  Click="Button_Click" Background="pink" Foreground="white" Height="19"/>
            <Button Content="Restart" HorizontalAlignment="Left" Margin="72,291,0,0" VerticalAlignment="Top" Width="114"  Click="Restart_Button_Click" Background="purple" Foreground="white" Height="21"/>
            <TextBlock HorizontalAlignment="Left" Margin="93,265,0,0" TextWrapping="Wrap" Text="✭Score:" VerticalAlignment="Top"/>
            <TextBlock x:Name="score" HorizontalAlignment="Left" Margin="147,265,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top" Height="14" RenderTransformOrigin="0.5,0.5" Width="15">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="14,39,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="🧡"/>
            <TextBlock HorizontalAlignment="Left" Margin="34,40,0,0" TextWrapping="Wrap" Text="3" VerticalAlignment="Top"/>
            <TextBlock HorizontalAlignment="Left" Margin="89,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" Text="⌛Time:" Height="16"/>
            <TextBlock HorizontalAlignment="Left" Margin="79,246,0,0" TextWrapping="Wrap" Text="🥇Record:" VerticalAlignment="Top"/>
            <TextBlock x:Name="Record" HorizontalAlignment="Left" Margin="147,246,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Height="14" RenderTransformOrigin="0.5,0.5" Width="15" />
            <TextBlock TextAlignment="Center" x:Name="firstNum" HorizontalAlignment="Left" Margin="91,62,0,0" VerticalAlignment="Top" FontSize="20px                    "/>
            <TextBlock TextAlignment="Center" x:Name="mathOp" HorizontalAlignment="Left" Margin="119,61,0,0" VerticalAlignment="Top" FontSize="20px                    " RenderTransformOrigin="0.298,0.511"/>
            <TextBlock TextAlignment="Center" x:Name="secondNum" HorizontalAlignment="Left" Margin="141,62,0,0" VerticalAlignment="Top" FontSize="20px                    " RenderTransformOrigin="0.49,0.272"/>
            <Button Content="⏸" HorizontalAlignment="Left" Margin="201,69,0,0" VerticalAlignment="Top" Height="32" Background="white" Foreground="black" FontSize="22px" Width="34"/>
            <TextBlock HorizontalAlignment="Left" Margin="129,56,0,0" TextWrapping="Wrap" FontSize="20px" Foreground="Orange" FontWeight="Bold" VerticalAlignment="Top"/>
            <TextBox x:Name="timerTB" HorizontalAlignment="Left" Margin="139,226,0,0" TextWrapping="Wrap" Text="99" VerticalAlignment="Top" Width="23" />
            <TextBox x:Name="resultTB" HorizontalAlignment="Left" Margin="84,109,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90" Height="25" TextChanged="resultTB_TextChanged" />
            <TextBlock HorizontalAlignment="Left" Margin="105,5,0,0" TextWrapping="Wrap" Text="Level:" VerticalAlignment="Top"/>
            <TextBlock Name="Level" HorizontalAlignment="Left" Margin="141,5,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top" Height="14"/>
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Margin="582,47,0,0">
            <Rectangle HorizontalAlignment="Left" Height="145" Stroke="Black" Fill="white" VerticalAlignment="Top" Width="156" RadiusX="14.062" RadiusY="14.062"/>
            <TextBlock HorizontalAlignment="Left" Margin="26,8,0,0" TextWrapping="Wrap" Foreground="Purple" FontWeight="Bold" VerticalAlignment="Top" Text="Moeilijkheidsniveau"/>
            <Button Name="Easy" Content="Makkelijk" Background="green" Click="Easy_Button_Click" FontWeight="Bold"  HorizontalAlignment="Left" Margin="33,35,0,0" VerticalAlignment="Top" Width="90" Height="27"/>
            <Button Name="Normal" Content="Normaal" Background="orange" Click="Mid_Button_Click" FontWeight="Bold" HorizontalAlignment="Left" Margin="33,68,0,0" VerticalAlignment="Top" Width="90" Height="30"/>
            <Button Name="Hard" Content="Moelijk" Background="red" Click="Hard_Button_Click" FontWeight="Bold" HorizontalAlignment="Left" Margin="33,104,0,0" VerticalAlignment="Top" Width="90" Height="30"/>
        </Grid>
    </Grid>
</Window>
